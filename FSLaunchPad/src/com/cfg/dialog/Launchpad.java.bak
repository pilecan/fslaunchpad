    private JPanel buildContentPane(Properties prop) {
		JPanel panel = new JPanel(new GridLayout(10,10,10,10));

		panel.setLayout(new FlowLayout());

        checkBoxAll.setSelected(false);
        checkBoxAll.addItemListener(new CheckboxAllListener(checkBoxAll));
        checkBoxAll.setText(prop.getProperty("pad.btn.all"));
        panel.add(checkBoxAll);

        JButton buttonAdd = new JButton(prop.getProperty("pad.btn.add"));
        panel.add(buttonAdd);
        buttonAdd.addActionListener(new AddApplicationListener());
        Dimension addSize = buttonAdd.getPreferredSize();
        addSize.width = 87;
        addSize.height = 35;
        buttonAdd.setPreferredSize(addSize);
        buttonAdd.setToolTipText(prop.getProperty("pad.btn.add.prog"));

        JButton buttonLaunch = new JButton(prop.getProperty("pad.btn.launch"));
		panel.add(buttonLaunch);
        Dimension launchSize = buttonLaunch.getPreferredSize();
        launchSize.width = addSize.width;
        launchSize.height = addSize.height;
        buttonLaunch.setPreferredSize(launchSize);
        buttonLaunch.setToolTipText(prop.getProperty("pad.btn.launch.sel"));
		
		JButton buttonQuit = new JButton(prop.getProperty("pad.btn.quit"));
		buttonQuit.addActionListener(new QuitListener());
		panel.add(buttonQuit);
		
		Dimension buttonSize = panel.getPreferredSize();
       // buttonSize.width = 80;
        buttonSize.height = 80;
        panel.setPreferredSize(buttonSize);
        
		buttonLaunch.addActionListener(new LaunchAllListener());
		
		panel.setBorder(new EmptyBorder(1,1, 1, 1));
		
		setSize(380, 400);
		setResizable(false);
		return panel;
	}
	
	
	public Launchpad(final JFrame parent, String title, int numColor, final JPanel basePanel, ManageConfigFile manageConfigFile){
		super(title);
		Util.setIcon(this, imageLogo);
		this.parent = parent;
		this.numColor = numColor;
	    checkBoxAll.setForeground(colorForground[numColor]);
	    checkBoxAll.setBackground(colorBackground[numColor]);
		this.basePanel = basePanel;
		this.manageConfigFile = manageConfigFile;
		prop = manageConfigFile.getProp();
    
	   addWindowListener(new WindowAdapter() {
            @Override
            public void windowClosing(WindowEvent e) {
            	quitLaunchpad();
            }
        });
	   
	//   setUndecorated(false);
       currentDirectory = "C:\\Program Files (x86)";
       launchMap = new TreeMap<String,LaunchLine>();
       initLaunchPad();
       loadSavedLaunch();
       
		
		getRootPane().setOpaque(false);
		
	    getRootPane().setBorder(BorderFactory.createEmptyBorder(
                15, //top
                20, //left    
                20, //bottom
                20) //right
                );
        
    
	    setSize(380, 420);
	    
/*	    Dimension dim = Toolkit.getDefaultToolkit().getScreenSize();
	    setLocation(dim.width/2 - getWidth()/2, dim.height/2 - getHeight()/2);
*/	   // setModal(true);
	    setLocationRelativeTo(parent);
	    
	    basePanel.setVisible(false);
	    setAlwaysOnTop(true);
	    parent.setEnabled(false);
		        
	    setVisible(true);
	    setResizable(false);

	}
	
	private void initLaunchPad(){
