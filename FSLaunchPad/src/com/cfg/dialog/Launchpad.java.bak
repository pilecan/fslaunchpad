        areaName.setPreferredSize(titleSize);
        JButton buttonHelp = new JButton("?");
        buttonHelp.addActionListener(new HelpListener());
        

        JPanel titlePanel = new JPanel();
        titlePanel.setLayout(new BoxLayout(titlePanel, BoxLayout.X_AXIS));
        titlePanel.add(label);
        titlePanel.add(areaName, BorderLayout.EAST);
        titlePanel.add(Box.createRigidArea(new Dimension(5,0)));
        titlePanel.add(buttonHelp);
        
        titlePanel.setOpaque(false);
        
        headerForm.add(titlePanel);

        headerForm.setBorder(new EmptyBorder(2,2, 2, 2));
        headerForm.setOpaque(false);
        panelHeader = new JPanel();
        panelHeader.add(headerForm);
/*	        panelHeader.setBackground(Color.black);
        panelHeader.setForeground(Color.white);
*/        
        buttonForm.setBorder(new EmptyBorder(1,1, 1, 1));
        panelButton = new JPanel();
	        
        panelButton.add(buttonForm);
        
	    splitPaneTop  =  new JSplitPane(JSplitPane.VERTICAL_SPLIT, true, panelHeader, new JScrollPane(panelButton)){
		 		private static final long serialVersionUID = 1L;
		 		private final int location = 40;
		     	    {
		     	        setDividerLocation( location );
		     	    }
		     	    @Override
		     	    public int getDividerLocation() {
		     	        return location ;
		     	    }
		     	    @Override
		     	    public int getLastDividerLocation() {
		     	        return location ;
		     	    }
		     	    
		    	
		     };
        
        splitPaneLaunch = new JSplitPane(JSplitPane.VERTICAL_SPLIT, true, splitPaneTop, buildContentPane(prop)){
 		private static final long serialVersionUID = 1L;
 		private final int location = 310;
     	    {
     	        setDividerLocation( location );
     	    }
     	    @Override
     	    public int getDividerLocation() {
     	        return location ;
     	    }
     	    @Override
     	    public int getLastDividerLocation() {
     	        return location ;
     	    }
        };
   
	    splitPaneTop.setDividerSize(0);
	    splitPaneTop.setVisible(true);
	    splitPaneLaunch.setDividerSize(0);
	    splitPaneLaunch.setVisible(true);
	    
	    getContentPane().add(splitPaneLaunch);

	}
	
	public void createLaunchButton(String filePath){
		String fileName = filePath.substring(filePath.lastIndexOf("\\")+1);
		
		//System.out.println(filePath.substring(filePath.lastIndexOf("\\")+1));
		JPanel panelLine = new JPanel(new GridLayout(10,10,10,10));
		panelLine.setLayout(new FlowLayout());
		
	//	panelLine.getRootPane().setOpaque(false);
		panelLine.setBackground (new Color (0, 0, 0, 0));
		panelLine.setOpaque(true);
	    
        JButton buttonLaunch = new JButton(fileName);
        //JButton buttonLaunch = new JButton("<html> <body bgcolor='black'>"+fileName+"</body></html>");
        buttonLaunch.addActionListener(new LaunchActionListener(fileName));
        
        buttonLaunch.setPreferredSize(new Dimension(200, 25));
        buttonLaunch.setToolTipText(filePath);

        JCheckBox launchCheckBox = new JCheckBox();
        launchCheckBox.setSelected(false);
        launchCheckBox.addItemListener(new CheckboxListener(buttonLaunch));
        launchCheckBox.setBackground(colorBackground[numColor]);

        JButton buttonDel = new JButton("X");
        buttonDel.addActionListener(new DeleteActionListener(fileName));
        buttonDel.setToolTipText(prop.getProperty("pad.remove.tip"));
        
        launchMap.put(fileName, new LaunchLine(launchCheckBox, buttonLaunch, buttonDel, panelLine, fileName, filePath));

        panelLine.add(launchCheckBox);
        panelLine.add(buttonLaunch);
        panelLine.add(buttonDel);
        panelLine.revalidate();

       // setUndecorated(true);
      //  buttonForm.setOpaque(false);
      //  buttonForm.setBackground (new Color (0, 0, 0, 0));
	   // setBackground (new Color (0, 0, 0, 0));

        
        buttonForm.add(panelLine);
        //panelButton.add(buttonForm);
        
	    setVisible(true);
        revalidate();
		
	}
	
	public class HelpListener implements ActionListener {
		
		public void actionPerformed(ActionEvent e) {
			JOptionPane.showMessageDialog(panelButton, getLabel(prop.getProperty("pad.name.help")));
		}    
	}

	public class AddApplicationListener implements ActionListener   {

		public void actionPerformed(ActionEvent arg0) {
			JFileChooser chooser = selectDirectoryProgram(prop.getProperty("pad.select.title"), currentDirectory);
	        setAlwaysOnTop(false);

			if (chooser.showOpenDialog(null) == JFileChooser.APPROVE_OPTION) {
				//System.out.println(chooser.getSelectedFile());
		        
				String filePath = chooser.getSelectedFile().toString();
				currentDirectory =  chooser.getSelectedFile().getPath();
				
				createLaunchButton(filePath);
				ManageConfigFile.saveLaunchList(launchMap);
			}
			
	        setAlwaysOnTop(false);

			//frame.setEnabled(true);
		}
		
	    private JFileChooser selectDirectoryProgram(String title,String directory){
			JFileChooser chooser = new JFileChooser();
			chooser.setCurrentDirectory(new java.io.File(directory));
			chooser.setDialogTitle(title);
			chooser.setFileSelectionMode(JFileChooser.FILES_ONLY);
			chooser.setAcceptAllFileFilterUsed(false);
			String[] EXTENSION=new String[]{"exe","doc","xls","xlsx","pdf","txt","cfg"};
			 FileNameExtensionFilter filter=new FileNameExtensionFilter("exe, doc, xls, xlsx, pdf, txt, cfg",EXTENSION);
			 chooser.setFileFilter(filter);
			 chooser.setMultiSelectionEnabled(false);
			
			return chooser;
	    	
	    }
		
	}
	
	private void loadSavedLaunch(){
		List<String> lines = ManageConfigFile.readLaunchList();
		
		int cptExist = 0;
		for(String line:lines){
			if (FileUtil.isFileExist(line)){
				cptExist++;
			   createLaunchButton(line);
			}
		}
		
		if (lines.size() != cptExist){
			ManageConfigFile.saveLaunchList(launchMap);
		}
		
	}
	
	
	
	public class CheckboxListener implements ItemListener   {
		private JButton button;
		public CheckboxListener(JButton button){
			this.button = button;
		}

        public void itemStateChanged(ItemEvent e) {
            button.setEnabled(e.getStateChange() == ItemEvent.DESELECTED);
        }

	}
	
	public class LaunchActionListener implements ActionListener   {
		private String name;
		public LaunchActionListener(String name){
			this.name = name;
		}

		public void actionPerformed(ActionEvent arg0) {
		
			launchProgram(launchMap.get(name).getPath());
		
		}
		
	}

	public class DeleteActionListener implements ActionListener   {
		private String name;
		public DeleteActionListener(String name){
			this.name = name;
		}

		public void actionPerformed(ActionEvent arg0) {
			//System.out.println(name);
			SwingUtilities.invokeLater(new Runnable() {
	            public void run() {
					currentDirectory =  launchMap.get(name).getPath();

	            	launchMap.get(name).getPanelLine().removeAll();
					launchMap.get(name).getPanelLine().revalidate();
					launchMap.get(name).getPanelLine().repaint();
					
					buttonForm.remove(launchMap.get(name).getPanelLine());
					buttonForm.revalidate();
					buttonForm.repaint();
					
					panelButton.revalidate();
					panelButton.repaint();
					
					launchMap.remove(name);
					
					ManageConfigFile.saveLaunchList(launchMap);
					
	            }
	         });
		}
		
	}

	
	public class LaunchAllListener implements ActionListener   {

		public void actionPerformed(ActionEvent arg0) {
			
			boolean isLaunchAll = false;
	        setVisible(false);
	        dispose();
	        parent.setEnabled(true);
		  
			if ("".equals(areaName.getText().trim())){
				int returnValue = JOptionPane.showConfirmDialog(panelButton, getLabel(prop.getProperty("pad.name.err")), "CAUTION", JOptionPane.YES_NO_OPTION);
				if (returnValue == 0){
					isLaunchAll = true;
				} else {
					//JOptionPane.showMessageDialog(panelButton,getLabel("Please Give a Name!") );
					quitLaunchpad();
					return;
				}
			} 
	        
    	    manageConfigFile.setAreaName(areaName.getText().trim());
  	    	manageConfigFile.getPrefs().setProperty("areaName", areaName.getText().trim());
  	    	manageConfigFile.savePrefProperties();
  	    	
			Object selected[] = manageConfigFile.getMapDestination(true);
			try {
				manageConfigFile.launchFlightSimulator(new ArrayList<Object>(Arrays.asList(selected)));
			    for(String key:launchMap.keySet()){
			    	if (launchMap.get(key).getCheckBox().isSelected()){
			    		launchProgram(launchMap.get(key).getPath());
			    	}
			    }
			} catch (Exception e) {
				// TODO Auto-generated catch block
				JOptionPane.showMessageDialog(panelButton,getLabel(prop.getProperty("fsx.mess.err")) );
			} finally {
			  //  FileUtil.setCurrentDirectory(manageConfigFile.getApplicationRoot());
			}
		    basePanel.setVisible(true);
		}
		
		
	}

		
	public class CheckboxAllListener implements ItemListener   {
		JCheckBox checkBox;
		public CheckboxAllListener(JCheckBox checkBox ){
			this.checkBox = checkBox;
		}

        public void itemStateChanged(ItemEvent e) {
            //System.out.println(checkBox.isSelected());
		    for(String key:launchMap.keySet()){
		    	launchMap.get(key).getCheckBox().setSelected(checkBox.isSelected());
		    	
		    }
        }

	}

	
	private class QuitListener implements ActionListener {
	    public void actionPerformed(ActionEvent e) {
	    	quitLaunchpad();
 	   }
	    
	    
	}
	
	public void quitLaunchpad(){
        setVisible(false);
        dispose();
        parent.setEnabled(true);
        basePanel.setFocusable(true);
        basePanel.setVisible(true);
        basePanel.setEnabled(true);
        parent.setAlwaysOnTop(true);
        parent.setAlwaysOnTop(false);
		
	}
	
    private void launchProgram(String fileName){
    	String[] PathName = FileUtil.getPathAndName(fileName);   
       // FileUtil.setCurrentDirectory(PathName[0]);
  		try {
			if (fileName.contains(".jar")){
	   	        Runtime runTime = Runtime.getRuntime();
	   	        Process process = runTime.exec("java -jar "+fileName);				
	   	  } else 	if (fileName.contains(".xls") || fileName.contains(".pdf") ||fileName.contains(".doc") || fileName.contains(".txt")|| fileName.contains(".cfg")){
    	        String[] commands = {"cmd", "/c", "start", "\"DummyTitle\"",fileName};
    	        Runtime.getRuntime().exec(commands);
	    		
	    	} else {
				Runtime rt = Runtime.getRuntime();
				Process ps = rt.exec(fileName, null, new File(PathName[0]));
	    	}
	    			
		} catch (IOException e1) {
			System.err.println(e1);
		}
    	
    }
    
    private JLabel getLabel(String text){
    	JLabel label = new JLabel();
    	label.setText(text);
    	label.setForeground(colorForground[numColor]);
    	label.setFont(fontText);
    	return label;
    }

    
	
